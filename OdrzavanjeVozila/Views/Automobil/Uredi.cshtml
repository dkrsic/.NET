@model OdrzavanjeVozila.Models.AutomobilEditModel
@{
    ViewData["Title"] = "Uredi automobil";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb app-breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Početna</a></li>
        <li class="breadcrumb-item"><a asp-controller="Automobil" asp-action="Index">Automobili</a></li>
        <li class="breadcrumb-item active">Uredi</li>
    </ol>
</nav>

<section class="entity-shell">
    <div class="entity-head">
        <h2>Uredi vozilo</h2>
    </div>
    <div class="detail-card">
        <form asp-action="Uredi" method="post" class="row g-3">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="col-md-6">
                <label asp-for="Marka" class="form-label"></label>
                <input asp-for="Marka" class="form-control" />
                <span asp-validation-for="Marka" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Model" class="form-label"></label>
                <input asp-for="Model" class="form-control" />
                <span asp-validation-for="Model" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Godiste" class="form-label"></label>
                <input asp-for="Godiste" class="form-control" />
                <span asp-validation-for="Godiste" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="RegistracijskiBroj" class="form-label"></label>
                <input asp-for="RegistracijskiBroj" class="form-control" />
                <span asp-validation-for="RegistracijskiBroj" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="BrojSasije" class="form-label"></label>
                <input asp-for="BrojSasije" class="form-control" />
                <span asp-validation-for="BrojSasije" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="TrenutnaKilometraza" class="form-label"></label>
                <input asp-for="TrenutnaKilometraza" class="form-control" />
                <span asp-validation-for="TrenutnaKilometraza" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="VrstaPogona" class="form-label"></label>
                <select asp-for="VrstaPogona" class="form-select">
                    <option value="">-- odaberi --</option>
                    @foreach (OdrzavanjeVozila.Tools.VrstaPogona val in Enum.GetValues(typeof(OdrzavanjeVozila.Tools.VrstaPogona)))
                    {
                        <option value="@val" selected="@(Model.VrstaPogona == val ? "selected" : null)">@val</option>
                    }
                </select>
                <span asp-validation-for="VrstaPogona" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="DatumPrvogServisa" class="form-label"></label>
                @await Html.PartialAsync("_DateTimePicker", new OdrzavanjeVozila.Models.DateTimePickerModel { FieldName = "DatumPrvogServisa", FieldId = "DatumPrvogServisa", Value = Model?.DatumPrvogServisa })
            </div>

            <div class="col-md-6">
                <label class="form-label">Vlasnik</label>
                <select asp-for="KorisnikId" class="form-select js-ajax-autocomplete" asp-items="ViewBag.Korisnici" data-autocomplete-url="@Url.Action("AutocompleteKorisnici", "Automobil")" data-autocomplete-placeholder="Pretraži korisnika..."></select>
                <span asp-validation-for="KorisnikId" class="text-danger"></span>
            </div>

            <div class="col-12 d-flex gap-2 pt-2">
                <button type="submit" class="btn btn-primary">Spremi promjene</button>
                <a asp-controller="Automobil" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Povratak</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

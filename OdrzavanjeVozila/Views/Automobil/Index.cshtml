@model List<OdrzavanjeVozila.Klase.Automobil>
@{
    ViewData["Title"] = "Automobili";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb app-breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Početna</a></li>
        <li class="breadcrumb-item active">Automobili</li>
    </ol>
</nav>

<section class="entity-shell">
    <div class="entity-head">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h2>Popis automobila</h2>
            </div>
            <a asp-controller="Automobil" asp-action="Kreiraj" class="btn btn-primary">Novi automobil</a>
        </div>
    </div>
    <div class="row g-3 mb-3">
        <div class="col-12 col-lg-6">
            <label for="automobilSearch" class="form-label visually-hidden">Pretraga automobila</label>
            <input id="automobilSearch" type="search" class="form-control" placeholder="Pretraži vozilo, registraciju ili vlasnika" autocomplete="off" data-search-url="@Url.Action("Pretrazi", "Automobil")" />
        </div>
    </div>
    <div class="table-responsive glass-table">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Vozilo</th>
                    <th>Registracija</th>
                    <th>Kilometraža</th>
                    <th>Pogon</th>
                    <th>Vlasnik</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="automobilRows">
                @await Html.PartialAsync("_Rows", Model)
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
}
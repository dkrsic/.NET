@model OdrzavanjeVozila.Models.DioEditModel
@{
    ViewData["Title"] = "Uredi dio";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb app-breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Početna</a></li>
        <li class="breadcrumb-item"><a asp-controller="Dio" asp-action="Index">Dijelovi</a></li>
        <li class="breadcrumb-item active">Uredi</li>
    </ol>
</nav>

<section class="entity-shell">
    <div class="entity-head"><h2>Uredi dio</h2></div>
    <div class="detail-card">
        <form asp-action="Uredi" method="post" class="row g-3">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="col-md-6">
                <label asp-for="Naziv" class="form-label"></label>
                <input asp-for="Naziv" class="form-control" />
                <span asp-validation-for="Naziv" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="KatalogBroj" class="form-label"></label>
                <input asp-for="KatalogBroj" class="form-control" />
                <span asp-validation-for="KatalogBroj" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Proizvodac" class="form-label"></label>
                <input asp-for="Proizvodac" class="form-control" />
                <span asp-validation-for="Proizvodac" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="Cijena" class="form-label"></label>
                <input asp-for="Cijena" class="form-control" />
                <span asp-validation-for="Cijena" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="KolicinaNaSkladistu" class="form-label"></label>
                <input asp-for="KolicinaNaSkladistu" class="form-control" />
                <span asp-validation-for="KolicinaNaSkladistu" class="text-danger"></span>
            </div>

            <div class="col-12">
                <label asp-for="Opis" class="form-label"></label>
                <textarea asp-for="Opis" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Opis" class="text-danger"></span>
            </div>

            <div class="col-12 d-flex gap-2 pt-2">
                <button type="submit" class="btn btn-primary">Spremi promjene</button>
                <a asp-controller="Dio" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Povratak</a>
            </div>
        </form>
    </div>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }

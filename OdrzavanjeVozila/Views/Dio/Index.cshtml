@model List<OdrzavanjeVozila.Klase.Dio>
@{
    ViewData["Title"] = "Dijelovi";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb app-breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Početna</a></li>
        <li class="breadcrumb-item active">Dijelovi</li>
    </ol>
</nav>

<section class="entity-shell">
    <div class="entity-head">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h2>Skladište dijelova</h2>
            </div>
            <a asp-controller="Dio" asp-action="Kreiraj" class="btn btn-primary">Novi dio</a>
        </div>
    </div>
    <div class="row g-3 mb-3">
        <div class="col-12 col-lg-6">
            <label for="dioSearch" class="form-label visually-hidden">Pretraga dijelova</label>
            <input id="dioSearch" type="search" class="form-control" placeholder="Pretraži naziv, katalog, proizvođača ili kategoriju" autocomplete="off" data-search-url="@Url.Action("Pretrazi", "Dio")" />
        </div>
    </div>
    <div class="table-responsive glass-table">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Naziv</th>
                    <th>Katalog br.</th>
                    <th>Proizvođač</th>
                    <th>Kategorija</th>
                    <th>Cijena</th>
                    <th>Na skladištu</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="dioRows">
                @await Html.PartialAsync("_Rows", Model)
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            const searchInput = document.getElementById('dioSearch');
            const rowsTarget = document.getElementById('dioRows');
            const searchUrl = searchInput.dataset.searchUrl;
            let timer = null;

            async function loadRows(query) {
                const response = await fetch(`${searchUrl}?q=${encodeURIComponent(query)}`, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                rowsTarget.innerHTML = await response.text();
            }

            searchInput.addEventListener('input', function () {
                clearTimeout(timer);
                timer = setTimeout(() => loadRows(searchInput.value), 250);
            });
        })();
    </script>
}
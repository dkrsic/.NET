@model List<OdrzavanjeVozila.Klase.Korisnik>
@{
    ViewData["Title"] = "Korisnici";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb app-breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Početna</a></li>
        <li class="breadcrumb-item active">Korisnici</li>
    </ol>
</nav>

<section class="entity-shell">
    <div class="entity-head">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h2>Popis korisnika</h2>
            </div>
            <a asp-controller="Korisnik" asp-action="Kreiraj" class="btn btn-primary">Novi korisnik</a>
        </div>
    </div>
    <div class="row g-3 mb-3">
        <div class="col-12 col-lg-6">
            <label for="korisnikSearch" class="form-label visually-hidden">Pretraga korisnika</label>
            <input id="korisnikSearch" type="search" class="form-control" placeholder="Pretraži ime, email, telefon ili adresu" autocomplete="off" data-search-url="@Url.Action("Pretrazi", "Korisnik")" />
        </div>
    </div>
    <div class="table-responsive glass-table">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Ime i prezime</th>
                    <th>Email</th>
                    <th>Telefon</th>
                    <th>Adresa</th>
                    <th>Datum registracije</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="korisnikRows">
                @await Html.PartialAsync("_Rows", Model)
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            const searchInput = document.getElementById('korisnikSearch');
            const rowsTarget = document.getElementById('korisnikRows');
            const searchUrl = searchInput.dataset.searchUrl;
            let timer = null;

            async function loadRows(query) {
                const response = await fetch(`${searchUrl}?q=${encodeURIComponent(query)}`, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                rowsTarget.innerHTML = await response.text();
            }

            searchInput.addEventListener('input', function () {
                clearTimeout(timer);
                timer = setTimeout(() => loadRows(searchInput.value), 250);
            });
        })();
    </script>
}
@model IEnumerable<OdrzavanjeVozila.Klase.Korisnik>

@foreach (var korisnik in Model)
{
    <tr>
        <td>@korisnik.PunoIme</td>
        <td>@korisnik.Email</td>
        <td>@korisnik.Telefon</td>
        <td>@korisnik.Adresa</td>
        <td>@korisnik.DatumRegistracije.ToString("dd.MM.yyyy")</td>
        <td class="row-action-cell">
            <span class="row-action-rail">
                <a asp-controller="Korisnik" asp-action="Uredi" asp-route-id="@korisnik.Id" class="row-action-link row-action-link-edit">Uredi</a>
                <a asp-controller="Korisnik" asp-action="Details" asp-route-id="@korisnik.Id" class="row-action-link row-action-link-details">Detalji</a>
                <a asp-controller="Korisnik" asp-action="Obrisi" asp-route-id="@korisnik.Id" class="row-action-link row-action-link-delete">Obriši</a>
            </span>
        </td>
    </tr>
}
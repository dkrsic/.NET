@model List<OdrzavanjeVozila.Klase.ServisniNalog>
@{
    ViewData["Title"] = "Servisni nalozi";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb app-breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Početna</a></li>
        <li class="breadcrumb-item active">Servisni nalozi</li>
    </ol>
</nav>

<section class="entity-shell">
    <div class="entity-head">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h2>Servisni nalozi</h2>
            </div>
            <a asp-controller="ServisniNalog" asp-action="Kreiraj" class="btn btn-primary">Novi servisni nalog</a>
        </div>
    </div>
    <div class="row g-3 mb-3">
        <div class="col-12 col-lg-6">
            <label for="servisniNalogSearch" class="form-label visually-hidden">Pretraga servisnih naloga</label>
            <input id="servisniNalogSearch" type="search" class="form-control" placeholder="Pretraži vozilo, mehaničara, status ili napomenu" autocomplete="off" data-search-url="@Url.Action("Pretrazi", "ServisniNalog")" />
        </div>
    </div>
    <div class="table-responsive glass-table">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Datum</th>
                    <th>Vozilo</th>
                    <th>Mehaničar</th>
                    <th>Status</th>
                    <th>Cijena</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="servisniNalogRows">
                @await Html.PartialAsync("_Rows", Model)
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            const searchInput = document.getElementById('servisniNalogSearch');
            const rowsTarget = document.getElementById('servisniNalogRows');
            const searchUrl = searchInput.dataset.searchUrl;
            let timer = null;

            async function loadRows(query) {
                const response = await fetch(`${searchUrl}?q=${encodeURIComponent(query)}`, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                rowsTarget.innerHTML = await response.text();
            }

            searchInput.addEventListener('input', function () {
                clearTimeout(timer);
                timer = setTimeout(() => loadRows(searchInput.value), 250);
            });
        })();
    </script>
}
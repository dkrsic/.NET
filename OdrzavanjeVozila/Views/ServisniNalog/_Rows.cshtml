@model IEnumerable<OdrzavanjeVozila.Klase.ServisniNalog>

@foreach (var nalog in Model)
{
    var statusText = nalog.Status.ToString();
    var statusKey = statusText.ToLowerInvariant();
    var statusClass = statusKey.Contains("zavr") || statusKey.Contains("dovr")
        ? "status-done"
        : statusKey.Contains("otvor") || statusKey.Contains("tijek")
            ? "status-progress"
            : "status-wait";

    <tr>
        <td>@nalog.DatumOtvaranja.ToString("dd.MM.yyyy")</td>
        <td>@(nalog.Automobil?.Naziv ?? "-")</td>
        <td>@(nalog.Mehanicar?.PunoIme ?? "-")</td>
        <td><span class="status-chip @statusClass">@statusText</span></td>
        <td>@nalog.UkupnaCijena.ToString("N2") €</td>
        <td>
            <a asp-controller="ServisniNalog" asp-action="Uredi" asp-route-id="@nalog.Id">Uredi</a>
            |
            <a asp-controller="ServisniNalog" asp-action="Details" asp-route-id="@nalog.Id">Detalji</a>
            |
            <a asp-controller="ServisniNalog" asp-action="Obrisi" asp-route-id="@nalog.Id">Obriši</a>
        </td>
    </tr>
}
@model List<OdrzavanjeVozila.Klase.Radionica>
@{
    ViewData["Title"] = "Radionice";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb app-breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Početna</a></li>
        <li class="breadcrumb-item active">Radionice</li>
    </ol>
</nav>

<section class="entity-shell">
    <div class="entity-head">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h2>Popis radionica</h2>
            </div>
            <a asp-controller="Radionica" asp-action="Kreiraj" class="btn btn-primary">Nova radionica</a>
        </div>
    </div>
    <div class="row g-3 mb-3">
        <div class="col-12 col-lg-6">
            <label for="radionicaSearch" class="form-label visually-hidden">Pretraga radionica</label>
            <input id="radionicaSearch" type="search" class="form-control" placeholder="Pretraži naziv, adresu, telefon ili email" autocomplete="off" data-search-url="@Url.Action("Pretrazi", "Radionica")" />
        </div>
    </div>
    <div class="table-responsive glass-table">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Naziv</th>
                    <th>Adresa</th>
                    <th>Telefon</th>
                    <th>Email</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="radionicaRows">
                @await Html.PartialAsync("_Rows", Model)
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
}